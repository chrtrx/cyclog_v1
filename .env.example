# ─────────────────────────────────────────────
# Supabase (Datenbank + Login + Sync)
# Findest du in deinem Supabase-Projekt unter:
# Settings → API
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein_anon_key_hier

# ─────────────────────────────────────────────
# Strava OAuth
# Findest du unter: https://www.strava.com/settings/api
# ─────────────────────────────────────────────
VITE_STRAVA_CLIENT_ID=123456
# Das Client Secret NIEMALS ins Frontend!
# Es liegt nur in der Supabase Edge Function (server-seitig).
